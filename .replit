modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const lib = require('./src/index.js'); const { Consolefy } = require('@mengkodingan/consolefy'); console.log('[@itsreimau/gktw] Library loaded successfully!'); console.log('Exports: ' + Object.keys(lib).join(', ')); process.stdin.resume();\""

[workflows.workflow.metadata]
outputType = "console"
